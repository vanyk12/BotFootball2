
# ─── Telegram Bot ───
BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
BOT_USERNAME=football_organizer_bot

# ─── Webhook / Mini App URL ───
# Public HTTPS URL of your Railway app (e.g. https://myapp.up.railway.app)
WEBHOOK_URL=https://your-app.up.railway.app
MINI_APP_URL=https://your-app.up.railway.app

# ─── Database (Supabase / PostgreSQL) ───
# Supabase pooler connection string (port 6543) — uses pgbouncer
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# ─── Admin Telegram IDs (comma-separated) ───
ADMIN_IDS=123456789,987654321

# ─── Reminder chat ID (group/channel where bot posts reminders) ───
REMINDER_CHAT_ID=-1001234567890
